# 文件分享核心代码
# 文件下载核心代码
contract hash {
     event AddRecordResult (int256 count);
     event GetRecordResult (string filehash);

     TableFactory tableFactory;
     string constant TABLE_NAME = "hash";
     constructor() public {
         tableFactory = TableFactory(0x1001);
         tableFactory.createTable(TABLE_NAME, "filename","filehash");
     }
     function addRecord(string memory filename, string memory filehash)
     public
     returns (int256)
     {
         Table table = tableFactory.openTable(TABLE_NAME);
         Entry entry = table.newEntry();
         entry.set("filename",filename);
         entry.set("filehash",filehash);
         int256 count = table.insert(filename, entry);
         emit AddRecordResult(count);
         return count;
     }
     function getRecord(string memory filename)
     public

     returns (string memory)
     {
         Table table = tableFactory.openTable(TABLE_NAME);
         Condition condition=table.newCondition();
         condition.EQ("filename",filename);
         Entries entries =table.select(filename, condition);
         require(entries.size()>0,"Record does not exist");
         Entry entry =entries.get(0);
         string memory filehash = entry.getString("filehash");
         emit GetRecordResult(filehash);
         return (filehash);
     }
 }

